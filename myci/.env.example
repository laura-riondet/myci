# Myci environment — copy to .env and fill in. The .env file is gitignored.

# ── Durable live store (Upstash Redis or Vercel KV) ──────────────────────────
# Without these, api/_store.js falls back to per-instance in-memory (demo only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Vercel KV uses the same code path via these aliases:
# KV_REST_API_URL=""
# KV_REST_API_TOKEN=""

# ── Magic-link auth email sender (Resend) ────────────────────────────────────
RESEND_API_KEY=""
AUTH_FROM_EMAIL="Myci <hello@yourdomain>"
